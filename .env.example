# === 163 邮箱 IMAP 配置 ===
EMAIL_IMAP_HOST=imap.163.com
EMAIL_ADDRESS=your_email@163.com
# 163邮箱授权码（非登录密码），需在邮箱设置中开启IMAP并生成
EMAIL_AUTH_CODE=your_auth_code_here

# === LLM API 配置 ===
# 默认使用 OpenRouter，也可替换为其他兼容 OpenAI 格式的 API 地址
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
# System Prompt（可在automail/config.py中自定义，不设置则使用内置默认 prompt）
# Fallback 模型列表（逗号分隔，留空则禁用 fallback；非 OpenRouter 用户请改为自己供应商支持的模型，也在automail/config.py中自定义）

# === 飞书机器人 Webhook ===
FEISHU_WEBHOOK_URL=your_webhook_url_here

# === 调度配置（每天几点执行） ===
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=30

# === IMAP 连接超时（秒） ===
IMAP_TIMEOUT=30

# === 首次运行时抓取的邮件数量 ===
FIRST_RUN_LIMIT=1
